{
  "manifest_version": 3,
  "name": "Avigilon Unity Sync",
  "version": "1.0.0",
  "description": "Synchronizes Avigilon Unity access control with AccessGrid mobile credentials",
  "permissions": [
    "storage",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "https://api.accessgrid.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Avigilon Unity Sync"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
